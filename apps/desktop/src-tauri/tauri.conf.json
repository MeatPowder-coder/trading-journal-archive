{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Trading Journal Desktop",
  "version": "0.1.0",
  "identifier": "xyz.agentame.tradingjournal.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Trading Journal Desktop",
        "width": 1320,
        "height": 860,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
